# ====================================
# AI Providers (API-first)
# ====================================

# Provider chain priority
# Options: groq, gemini
AI_PROVIDER_CHAIN=groq,gemini

# Primary provider: Groq
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL_NAME=openai/gpt-oss-20b
GROQ_TIMEOUT_SECONDS=45

# Fallback provider: Gemini
GOOGLE_GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=45

# Enable article generation step
# Default: true
PIPELINE_ENABLE_GENERATION=true

# Fast generation mode (limit articles processed)
# Default: true
FAST_GENERATION_MODE=true

# ====================================
# Data Collection Parameters
# ====================================

# Minimum number of articles to collect
# Default: 20
TARGET_MIN_ARTICLES=20

# Maximum number of articles to collect
# Default: 30
TARGET_MAX_ARTICLES=30

# Maximum articles per query/source
# Default: 6
MAX_ARTICLES_PER_QUERY=6

# Active multi-query theme packs used to build Google News RSS searches
# Options: tech, ia, data, marketing, business, startup, innovation, finance
# Default: tech,ia,data,marketing,business,startup,innovation,finance
ACTIVE_RSS_QUERY_THEMES=tech,ia,data,marketing,business,startup,innovation,finance

# Optional custom RSS queries (comma-separated) appended to active theme packs
# Example: france industrie 4.0, b2b saas
CUSTOM_RSS_QUERIES=

# ====================================
# Generation Parameters
# ====================================

# Maximum LLM articles to generate
# Default: 5
MAX_LLM_ARTICLES=5

# Total generated articles limit
# Default: 20
GENERATED_ARTICLES_LIMIT=20

# Top topics to generate articles for
# Default: 3
TOP_TOPICS_TO_GENERATE=3

# ====================================
# Notes
# ====================================

# Paste your 2 API keys above:
# - GROQ_API_KEY (primary / fastest)
# - GOOGLE_GEMINI_API_KEY (fallback)
